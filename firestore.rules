rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/client_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/client_users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Users ──────────────────────────────────────────────
    match /client_users/{userId} {
      // Users can read their own profile; admins can read any
      allow read: if isOwner(userId) || isAdmin();
      // Anyone authenticated can create their own profile
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.isBlocked == false;
      // Users can update their own profile (except role & isBlocked)
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.isBlocked == resource.data.isBlocked;
      // Admins can update any user (including role & isBlocked)
      allow update: if isAdmin();
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ── Events ─────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admins can update any field
      allow update: if isAdmin();
      // Authenticated users may only increment MembersParticipated by 1
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['MembersParticipated'])
        && request.resource.data.MembersParticipated == resource.data.MembersParticipated + 1;
    }

    // ── Team Members ───────────────────────────────────────
    match /team_members/{memberId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Blogs ──────────────────────────────────────────────
    match /blogs/{blogId} {
      allow read: if resource == null || resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Registrations ──────────────────────────────────────
    match /registrations/{regId} {
      // Doc ID must be {userId}_{eventId} — enforce ownership via ID
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && regId.matches(request.auth.uid + '_.*');
      // Users can read their own registrations (or check if one exists)
      allow read: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
      // Admins can read/update/delete any
      allow read, update, delete: if isAdmin();
    }

    // ── Gallery ────────────────────────────────────────────
    match /gallery/{imageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Deny everything else by default ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
