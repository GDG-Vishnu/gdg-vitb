rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/client_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/client_users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Users ──────────────────────────────────────────────
    match /client_users/{userId} {
      // Public read access for non-blocked users (for profile sharing)
      // Users can also read their own profile; admins can read any
      allow read: if (resource != null && resource.data.isBlocked == false) 
        || isOwner(userId) 
        || isAdmin();
      // Anyone authenticated can create their own profile
      allow create: if isOwner(userId)
        && request.resource.data.isBlocked == false;
      // Users can update their own profile (except isBlocked)
      allow update: if isOwner(userId)
        && request.resource.data.isBlocked == resource.data.isBlocked;
      // Admins can update any user (including isBlocked)
      allow update: if isAdmin();
      // Only admins can delete users
      allow delete: if isAdmin();

      // User's event registrations subcollection
      match /registrations/{eventId} {
        // Owner can create and read their own registrations
        allow create, read: if isOwner(userId);
        // Admins can read/update/delete any
        allow read, update, delete: if isAdmin();
      }
    }

    // ── Events (Legacy) ──────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admins can update any field
      allow update: if isAdmin();
    }

    // ── Managed Events ─────────────────────────────────────
    match /managed_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Registrations subcollection under each managed event
      match /registrations/{regId} {
        // Doc ID must be {userId}_{eventId} — enforce ownership via ID
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && regId.matches(request.auth.uid + '_.*');
        // Users can get their own registration doc
        allow get: if isAuthenticated()
          && (resource == null || resource.data.userId == request.auth.uid);
        // Allow authenticated users to run count aggregation queries
        // (getCountFromServer for maxParticipants check — does not expose doc contents)
        allow list: if isAuthenticated();
        // Admins can read/update/delete any
        allow read, update, delete: if isAdmin();
      }
    }

    // ── Team Members ───────────────────────────────────────
    match /team_members/{memberId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Blogs ──────────────────────────────────────────────
    match /blogs/{blogId} {
      allow read: if resource == null || resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Gallery ────────────────────────────────────────────
    match /gallery/{imageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Deny everything else by default ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
